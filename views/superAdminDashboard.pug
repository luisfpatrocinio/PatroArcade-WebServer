extends base.pug

block content
  section#superAdminPanel
    h1 PatroArcade Central

    if errorMessage
      .alert.alert-danger= errorMessage

    section#statsSection
      h2 Métricas Globais
      .metric-card
        .metric-label Total de Máquinas
        .metric-value= globalMetrics.totalMachines
      .metric-card
        .metric-label Máquinas Online
        .metric-value.online= globalMetrics.onlineMachines
      .metric-card
        .metric-label Total de Jogadores
        .metric-value= globalMetrics.totalPlayers

    section#allMachines
      h2 Controle de Máquinas
      if allArcades && allArcades.length > 0
        .games-vertical
          each arcade in allArcades
            .game-row.align-items-center
              div
                .game-title Maquina ID: #{arcade.id}
                .game-genre Dono: #{arcade.ownerName || arcade.user?.username || arcade.userId || 'Desconhecido'}
              a.btn-outline-info.btn-sm(href=`/dashboard/arcade/manage/${arcade.id}` style="padding: 5px 10px; border-radius: 4px; text-decoration: none;") Gerir
      else
        p.text-muted Nenhuma maquina registrada no servidor.

    section#gamesCatalog
      h2 Catalogo de Jogos
      if platformGames && platformGames.length > 0
        .games-vertical
          each game in platformGames
            .game-row
              .game-title= game.title
              .game-genre= game.genre || 'Arcade'
      else
        p.text-muted Nenhum jogo no catálogo.

    section#adminActions
      h2 Ações
      button.btn-success + Cadastrar Novo Jogo

    .back-button-container
      a.returnButton(href="/") Voltar ao Início