extends base.pug

block headExtra
  title Hall da Fama

block content
  section#playersList
    h2 Hall da Fama - Jogadores
    if playerDatabase && playerDatabase.length > 0
      each playerData in playerDatabase
        .card.bg-dark.border-secondary.mb-3.shadow
          .card-body
            .player-row
              .player-info
                a.text-info(href=`/player/${playerData.id || playerData.userId}`)= playerData.name
              .player-meta
                if playerData.lastGameId || playerData.lastGame
                  a.text-warning(href=`/game/${playerData.lastGameId || playerData.lastGame.id}`)= playerData.lastGame?.title || 'Jogo #' + playerData.lastGameId
                else
                  span.text-muted Nenhum
              .player-login
                if playerData.lastLogin
                  span.text-muted= new Date(playerData.lastLogin).toLocaleDateString('pt-BR')
                else
                  span.text-muted Recentemente
    else
      p.text-muted Nenhum jogador cadastrado no momento.

  .back-button-container
    a.returnButton(href="/") Voltar ao Início

block scripts
  script(src="/scripts/playersPage.js")