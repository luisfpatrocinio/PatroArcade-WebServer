extends base.pug

block headExtra 
    title Listagem de Jogadores 

block content 
    .container.mt-5.pt-4
        h2.mb-4.text-info Hall da Fama - Jogadores
        .row.g-4
            if playerDatabase && playerDatabase.length > 0
                each player in playerDatabase
                    .col-12.col-sm-6.col-lg-4
                        .card.bg-dark.text-light.border-secondary.h-100.shadow-sm
                            .card-body.d-flex.align-items-center
                                .flex-grow-1
                                    h5.card-title.mb-1= player.name
                                    p.card-text.text-muted ID Usuário: #{player.userId}
                                a.btn.btn-outline-info.btn-sm(href=`/player/${player.userId}`) Perfil
            else
                .col-12
                    .alert.alert-warning Nenhum jogador cadastrado no momento.

    .back-button-container.mt-5
        a.returnButton(href="/") Voltar ao Início

block scripts
    script(src="/scripts/playersPage.js")