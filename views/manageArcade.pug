extends base.pug

block content
  section#manageArcadePanel
    h2.mb-4(style="color: #1f6feb;") Gerenciar Máquina ID: #{arcadeId}

    .card.bg-dark.text-light.border-primary.mb-4.shadow
      .card-body.text-center
        h3.text-warning Status de Operação: Em Desenvolvimento
        p.text-muted Esta interface exibirá a telemetria avançada em tempo real da máquina futuramente.

    .row.g-3.mt-2
      .col-md-6
        button.btn.btn-outline-danger.w-100.py-2(disabled) Desligar Máquina Remotamente (Bloqueado)
      .col-md-6
        button.btn.btn-outline-success.w-100.py-2(disabled) Enviar Atualização de Jogo (Bloqueado)

    .back-button-container.mt-4
      a.returnButton(href="/dashboard/arcade") Voltar ao Painel