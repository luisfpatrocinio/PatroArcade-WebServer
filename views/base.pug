doctype html 
html 
    head 
        //- Bloco Head Extra
        block headExtra 

        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
        //- Sobrescrever CSS
        link(rel="stylesheet", href="/styles.css")
    
    body
        nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top.border-bottom.border-secondary
          .container
            a.navbar-brand(href="/games")
              img(src="/assets/patroArcadeLogo.png" alt="PatroArcade" height="30" class="d-inline-block align-text-top")
            button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
              span.navbar-toggler-icon
            .collapse.navbar-collapse#navbarNav
              ul.navbar-nav.ms-auto
                li.nav-item
                  a.nav-link(href="/games") Início
                if user && (user.role === 'admin' || user.role === 'superadmin')
                  li.nav-item
                    a.nav-link.text-info(href="/dashboard/arcade") Painel do Parceiro
                if user && user.role === 'superadmin'
                  li.nav-item
                    a.nav-link.text-warning(href="/admin/master") Central Mestre
                if user
                  li.nav-item
                    a.nav-link.text-danger(href="/logout") Sair

        //- Fundo de estrelas
        .stars

        //- Bloco de Conteúdo 
        block content 

        //- Um rodapé
        footer 
            p © 2025 - PatroArcade - Todos os direitos reservados.
            <a href="https://github.com/luisfpatrocinio">GitHub</a>
            <span> | </span>
            <a href="https://www.textstudio.com/">Font generator</a>
            <br><br>
            if !user
              a(href="/dashboard/arcade/login" style="font-weight: bold; background: rgba(31, 111, 235, 0.2); padding: 5px 10px; border-radius: 5px;") Área do Parceiro
            
        //- Adicionar algum script adicional
        block scripts 
            
            //- // Scripts comum a todas as páginas
            //- script(src="/scripts/main.js")
        
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")