doctype html 
html(lang="pt-br")
    head 
        //- Bloco Head Extra
        block headExtra 

        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
        //- Sobrescrever CSS
        link(rel="stylesheet", href="/styles.css")
    
    body
        nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top.border-bottom.border-secondary
          .container
            a.navbar-brand.d-flex.align-items-center(href="/games")
              img.me-2(src="/assets/patroArcadeLogo.png" alt="PatroArcade" height="40" style="object-fit: contain;")
            button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
              span.navbar-toggler-icon
            .collapse.navbar-collapse#navbarNav
              ul.navbar-nav.ms-auto.align-items-center
                li.nav-item
                  a.nav-link(href="/games") Início
                if user && (user.role === 'admin' || user.role === 'superadmin')
                  li.nav-item
                    a.nav-link.text-info(href="/dashboard/arcade") Painel do Parceiro
                if user && user.role === 'superadmin'
                  li.nav-item
                    a.nav-link.text-warning(href="/dashboard/admin/master") Central Mestre
                if user
                  li.nav-item
                    a.nav-link.text-danger(href="/logout") Sair

        //- Fundo de estrelas
        .stars

        //- Bloco de Conteúdo 
        block content 

        footer.footer.mt-auto.py-4.bg-dark.border-top.border-secondary
          .container.text-center
            p.text-muted.mb-2 © 2026 PatroArcade. Todos os direitos reservados.
            if !user || (user.role !== 'admin' && user.role !== 'superadmin')
              a.btn.btn-outline-primary.btn-sm.mt-2(href="/dashboard/arcade/login") Área do Parceiro
            
        //- Adicionalmente, você pode adicionar links úteis no rodapé se desejar
        //- a(href="https://github.com/luisfpatrocinio" class="text-muted mx-2") GitHub
            
        //- Adicionar algum script adicional
        block scripts 
        
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")