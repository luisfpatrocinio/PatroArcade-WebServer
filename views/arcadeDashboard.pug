extends base.pug

block content
  section(style="max-width: 900px; width: 95%;")
    h1 Painel de Gestão

    //- Banner de erro (se a API falhou)
    if errorMessage
      div(style="background: rgba(255,68,68,0.15); border: 1px solid #ff4444; border-radius: 8px; padding: 12px 20px; margin-bottom: 20px; color: #ff4444;")
        | ⚠️ #{errorMessage}

    //- Cards de resumo (Bootstrap Grid)
    .row.mb-4.g-3.justify-content-center
      .col-6.col-md-3
        .card.bg-dark.text-light.border-primary.text-center.h-100
          .card-body.p-3
            h6.card-subtitle.mb-2.text-primary.text-uppercase(style="font-size: 0.75rem; letter-spacing: 1px;") Total
            p.h2.mb-0.fw-bold #{summary.totalMachines}
      .col-6.col-md-3
        .card.bg-dark.text-light.border-success.text-center.h-100
          .card-body.p-3
            h6.card-subtitle.mb-2.text-success.text-uppercase(style="font-size: 0.75rem; letter-spacing: 1px;") Online
            p.h2.mb-0.fw-bold #{summary.activeMachines}
      .col-6.col-md-3
        .card.bg-dark.text-light.border-secondary.text-center.h-100
          .card-body.p-3
            h6.card-subtitle.mb-2.text-secondary.text-uppercase(style="font-size: 0.75rem; letter-spacing: 1px;") Offline
            p.h2.mb-0.fw-bold #{summary.totalMachines - summary.activeMachines}

    //- Listagem de Máquinas
    h2 Máquinas Cadastradas

    .row
      if arcades && arcades.length > 0
        each arcade in arcades
          .col-12.col-sm-6.col-lg-4.mb-4
            .card.bg-dark.text-light.border-secondary.h-100.shadow-sm
              .card-header.d-flex.justify-content-between.align-items-center.border-bottom.border-secondary
                h5.mb-0.text-info Máquina ID: #{arcade.id}
                if arcade.metrics && arcade.metrics.status === 'online'
                  span.badge.bg-success Online
                else
                  span.badge.bg-danger Offline
              .card-body
                p.card-text
                  strong Jogo Atual: 
                  span.text-warning.text-truncate.d-inline-block.max-w-100 #{arcade.gameName || 'Nenhum'}
                p.card-text
                  strong Tempo de Atividade: 
                  span.text-white #{arcade.metrics && arcade.metrics.uptimeMinutes ? arcade.metrics.uptimeMinutes + ' min' : 'Desligada'}
                p.card-text
                  strong Sessões: 
                  span.text-white #{arcade.metrics ? arcade.metrics.totalSessions : 0}
              .card-footer.border-top.border-secondary
                button.btn.btn-outline-info.btn-sm.w-100 Gerenciar Máquina
      else
        .col-12
          .alert.alert-secondary.text-center(role="alert")
            | Nenhuma máquina associada à sua conta no momento.

  .back-button-container
    a.returnButton(href="/") Voltar ao Início
