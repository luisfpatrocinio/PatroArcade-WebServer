extends base.pug

block content
  section(style="max-width: 900px; width: 95%;")
    h1 Painel de Gestão

    //- Banner de erro (se a API falhou)
    if errorMessage
      div(style="background: rgba(255,68,68,0.15); border: 1px solid #ff4444; border-radius: 8px; padding: 12px 20px; margin-bottom: 20px; color: #ff4444;")
        | ⚠️ #{errorMessage}

    //- Cards de resumo
    div(style="display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; margin-bottom: 28px;")
      div(style="background: rgba(0,0,0,0.45); border: 1px solid #1f6feb; border-radius: 10px; padding: 20px 30px; text-align: center; flex: 1; min-width: 160px;")
        h3(style="margin-top: 0; color: #a0c4ff; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;") Total de Máquinas
        p(style="font-size: 2.4rem; color: #ffffff; font-weight: bold; margin: 8px 0;") #{summary.totalMachines}
      div(style="background: rgba(0,0,0,0.45); border: 1px solid #39d353; border-radius: 10px; padding: 20px 30px; text-align: center; flex: 1; min-width: 160px;")
        h3(style="margin-top: 0; color: #a0c4ff; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;") Máquinas Online
        p(style="font-size: 2.4rem; color: #39d353; font-weight: bold; margin: 8px 0;") #{summary.activeMachines}
      div(style="background: rgba(0,0,0,0.45); border: 1px solid #888; border-radius: 10px; padding: 20px 30px; text-align: center; flex: 1; min-width: 160px;")
        h3(style="margin-top: 0; color: #a0c4ff; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;") Máquinas Offline
        p(style="font-size: 2.4rem; color: #aaaaaa; font-weight: bold; margin: 8px 0;") #{summary.totalMachines - summary.activeMachines}

    //- Tabela de Arcades
    h2 Máquinas Cadastradas

    if arcades.length === 0
      p(style="text-align: center; color: #888; padding: 20px;") Nenhuma máquina cadastrada para este estabelecimento.
    else
      .leaderboard-container
        table
          thead
            tr
              th ID
              th Estabelecimento
              th Status
              th Uptime
              th Sessões
              th Jogo Atual
          tbody
            each arcade in arcades
              tr
                td: h5.card-title.text-info Máquina ID: #{arcade.id}
                td #{arcade.name || arcade.location || '-'}
                td
                  if arcade.metrics && arcade.metrics.status === 'online'
                    span(style="color: #39d353; font-weight: bold; background: rgba(57,211,83,0.12); padding: 3px 10px; border-radius: 20px; border: 1px solid #39d353;") ● Online
                  else if arcade.metrics
                    span(style="color: #ff4444; font-weight: bold; background: rgba(255,68,68,0.12); padding: 3px 10px; border-radius: 20px; border: 1px solid #ff4444;") ● Offline
                  else
                    span(style="color: #888; padding: 3px 10px;") —
                td
                  if arcade.metrics && arcade.metrics.uptimeMinutes
                    | #{arcade.metrics.uptimeMinutes} min
                  else
                    span(style="color: #666;") Desligada
                td
                  if arcade.metrics
                    | #{arcade.metrics.totalSessions}
                  else
                    span(style="color: #666;") —
                td
                  if arcade.metrics && arcade.metrics.currentGameId
                    span.text-warning= arcade.gameName
                  else
                    span(style="color: #666;") Nenhum

  .back-button-container
    a.returnButton(href="/") Voltar ao Início
